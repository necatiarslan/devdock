{
  "name": "devdock",
  "displayName": "DevDock",
  "description": "A customizable developer dock for files, notes, scripts, and VS Code commands",
  "version": "1.0.0",
  "publisher": "NecatiARSLAN",
  "repository": {
    "type": "git",
    "url": "https://github.com/necatiarslan/devdock"
  },
  "icon": "media/devdock-logo-extension.png",
  "engines": {
    "vscode": "^1.106.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "developer",
    "productivity",
    "notes",
    "scripts",
    "files",
    "commands"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "DevDock.Add",
        "title": "Add",
        "icon": "$(add)"
      },
      {
        "command": "DevDock.Remove",
        "title": "Remove",
        "icon": "$(trash)"
      },
      {
        "command": "DevDock.Refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "DevDock.Filter",
        "title": "Filter",
        "icon": "$(filter)"
      },
      {
        "command": "DevDock.ShowOnlyFavorite",
        "title": "Show Only Favorite",
        "icon": "$(bookmark)"
      },
      {
        "command": "DevDock.ShowHidden",
        "title": "Show Hidden",
        "icon": "$(eye-closed)"
      },
      {
        "command": "DevDock.Hide",
        "title": "Hide"
      },
      {
        "command": "DevDock.UnHide",
        "title": "UnHide"
      },
      {
        "command": "DevDock.AddFav",
        "title": "Fav",
        "icon": "$(star)"
      },
      {
        "command": "DevDock.RemoveFav",
        "title": "UnFav",
        "icon": "$(star-empty)"
      },
      {
        "command": "DevDock.ShowOnlyInThisWorkspace",
        "title": "Show Only In This Workspace"
      },
      {
        "command": "DevDock.ShowInAnyWorkspace",
        "title": "Show In Any Workspace"
      },
      {
        "command": "DevDock.NodeAdd",
        "title": "Add",
        "icon": "$(add)"
      },
      {
        "command": "DevDock.NodeRemove",
        "title": "Remove",
        "icon": "$(trash)"
      },
      {
        "command": "DevDock.NodeRefresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "DevDock.NodeView",
        "title": "View",
        "icon": "$(eye)"
      },
      {
        "command": "DevDock.NodeEdit",
        "title": "Edit",
        "icon": "$(pencil)"
      },
      {
        "command": "DevDock.NodeRun",
        "title": "Run",
        "icon": "$(play)"
      },
      {
        "command": "DevDock.NodeStop",
        "title": "Stop",
        "icon": "$(stop)"
      },
      {
        "command": "DevDock.NodeOpen",
        "title": "Open",
        "icon": "$(go-to-file)"
      },
      {
        "command": "DevDock.NodeInfo",
        "title": "Info",
        "icon": "$(info)"
      },
      {
        "command": "DevDock.NodeCopy",
        "title": "Copy",
        "icon": "$(copy)"
      },
      {
        "command": "DevDock.NodeAlias",
        "title": "Alias",
        "icon": "$(case-sensitive)"
      },
      {
        "command": "DevDock.SetTooltip",
        "title": "Set Tooltip",
        "icon": "$(comment)"
      },
      {
        "command": "DevDock.MoveUp",
        "title": "Move Up",
        "icon": "$(arrow-up)"
      },
      {
        "command": "DevDock.MoveDown",
        "title": "Move Down",
        "icon": "$(arrow-down)"
      },
      {
        "command": "DevDock.MoveToFolder",
        "title": "Move to Folder",
        "icon": "$(folder)"
      },
      {
        "command": "DevDock.Donate",
        "title": "Donate",
        "icon": "$(heart)"
      },
      {
        "command": "DevDock.BugAndNewFeatureRequest",
        "title": "Bug and New Feature Request",
        "icon": "$(bug)"
      },
      {
        "command": "DevDock.ExportConfig",
        "title": "Export Config",
        "icon": "$(arrow-down)"
      },
      {
        "command": "DevDock.ImportConfig",
        "title": "Import Config",
        "icon": "$(arrow-up)"
      },
      {
        "command": "DevDock.ActivatePro",
        "title": "Activate Pro"
      },
      {
        "command": "DevDock.EnterLicenseKey",
        "title": "Enter License Key"
      },
      {
        "command": "DevDock.ResetLicenseKey",
        "title": "Reset License Key"
      }
    ],
    "submenus": [
      {
        "id": "DevDock.ProLicense",
        "label": "Pro License"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "DevDock.Add",
          "when": "view == DevDockView",
          "group": "navigation"
        },
        {
          "command": "DevDock.Filter",
          "when": "view == DevDockView",
          "group": "navigation"
        },
        {
          "command": "DevDock.ShowOnlyFavorite",
          "when": "view == DevDockView",
          "group": "navigation"
        },
        {
          "command": "DevDock.ShowHidden",
          "when": "view == DevDockView",
          "group": "navigation"
        },
        {
          "command": "DevDock.Refresh",
          "when": "view == DevDockView",
          "group": "navigation"
        },
        {
          "submenu": "DevDock.ProLicense",
          "when": "view == DevDockView",
          "group": "other_1"
        },
        {
          "command": "DevDock.Donate",
          "when": "view == DevDockView",
          "group": "other_2"
        },
        {
          "command": "DevDock.BugAndNewFeatureRequest",
          "when": "view == DevDockView",
          "group": "other_2"
        },
        {
          "command": "DevDock.ExportConfig",
          "when": "view == DevDockView",
          "group": "other_3"
        },
        {
          "command": "DevDock.ImportConfig",
          "when": "view == DevDockView",
          "group": "other_3"
        }
      ],
      "view/item/context": [
        {
          "command": "DevDock.AddFav",
          "when": "view == DevDockView && viewItem =~ /#AddFav#/",
          "group": "Filter"
        },
        {
          "command": "DevDock.RemoveFav",
          "when": "view == DevDockView && viewItem =~ /#RemoveFav#/",
          "group": "Filter"
        },
        {
          "command": "DevDock.Hide",
          "when": "view == DevDockView && viewItem =~ /#Hide#/",
          "group": "Filter"
        },
        {
          "command": "DevDock.UnHide",
          "when": "view == DevDockView && viewItem =~ /#UnHide#/",
          "group": "Filter"
        },
        {
          "command": "DevDock.ShowOnlyInThisWorkspace",
          "when": "view == DevDockView && viewItem =~ /#ShowOnlyInThisWorkspace#/",
          "group": "Filter"
        },
        {
          "command": "DevDock.ShowInAnyWorkspace",
          "when": "view == DevDockView && viewItem =~ /#ShowInAnyWorkspace#/",
          "group": "Filter"
        },
        {
          "command": "DevDock.NodeAlias",
          "when": "view == DevDockView && viewItem =~ /#NodeAlias#/",
          "group": "Filter"
        },
        {
          "command": "DevDock.SetTooltip",
          "when": "view == DevDockView && viewItem =~ /#SetTooltip#/",
          "group": "Customize"
        },
        {
          "command": "DevDock.MoveUp",
          "when": "view == DevDockView && viewItem =~ /#MoveUp#/",
          "group": "Order"
        },
        {
          "command": "DevDock.MoveDown",
          "when": "view == DevDockView && viewItem =~ /#MoveDown#/",
          "group": "Order"
        },
        {
          "command": "DevDock.MoveToFolder",
          "when": "view == DevDockView && viewItem =~ /#NodeMove#/",
          "group": "Order"
        },
        {
          "command": "DevDock.NodeAdd",
          "when": "view == DevDockView && viewItem =~ /#NodeAdd#/",
          "group": "inline@1"
        },
        {
          "command": "DevDock.NodeRemove",
          "when": "view == DevDockView && viewItem =~ /#NodeRemove#/",
          "group": "inline@2"
        },
        {
          "command": "DevDock.NodeRefresh",
          "when": "view == DevDockView && viewItem =~ /#NodeRefresh#/",
          "group": "inline@3"
        },
        {
          "command": "DevDock.NodeView",
          "when": "view == DevDockView && viewItem =~ /#NodeView#/",
          "group": "inline@4"
        },
        {
          "command": "DevDock.NodeEdit",
          "when": "view == DevDockView && viewItem =~ /#NodeEdit#/",
          "group": "inline@5"
        },
        {
          "command": "DevDock.NodeRun",
          "when": "view == DevDockView && viewItem =~ /#NodeRun#/",
          "group": "inline@6"
        },
        {
          "command": "DevDock.NodeStop",
          "when": "view == DevDockView && viewItem =~ /#NodeStop#/",
          "group": "inline@7"
        },
        {
          "command": "DevDock.NodeOpen",
          "when": "view == DevDockView && viewItem =~ /#NodeOpen#/",
          "group": "inline@8"
        },
        {
          "command": "DevDock.NodeInfo",
          "when": "view == DevDockView && viewItem =~ /#NodeInfo#/",
          "group": "inline@9"
        },
        {
          "command": "DevDock.NodeCopy",
          "when": "view == DevDockView && viewItem =~ /#NodeCopy#/",
          "group": "inline@10"
        }
      ],
      "DevDock.ProLicense": [
        {
          "command": "DevDock.EnterLicenseKey",
          "group": "1_license"
        },
        {
          "command": "DevDock.ResetLicenseKey",
          "group": "1_license"
        },
        {
          "command": "DevDock.ActivatePro",
          "group": "1_license"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "DevDock",
          "title": "DevDock",
          "icon": "media/devdock-logo-activitybar.png"
        }
      ]
    },
    "views": {
      "DevDock": [
        {
          "id": "DevDockView",
          "name": "DevDock",
          "icon": "media/devdock-logo-activitybar.png"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "DevDockView",
        "contents": "Click [+] to add items to your dock.\n [Add](command:DevDock.Add)\n\nPin files, create notes, save shell snippets, and keep VS Code commands close at hand."
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/glob": "^9.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.0",
    "@types/tmp": "^0.2.6",
    "@types/vscode": "^1.106.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^10.0.3",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@types/uuid": "^11.0.0",
    "@vscode-elements/elements": "^2.5.1",
    "@vscode/codicons": "^0.0.45",
    "archiver": "^7.0.1",
    "js-tiktoken": "^1.0.21",
    "js-yaml": "^4.1.1",
    "reflect-metadata": "^0.2.2",
    "tmp": "^0.2.5",
    "uuid": "^13.0.0",
    "yauzl": "^3.2.1"
  },
  "overrides": {
    "archiver": {
      "readdir-glob": "3.0.0"
    },
    "archiver-utils": {
      "glob": {
        "minimatch": "9.0.9"
      }
    },
    "mocha": {
      "diff": "8.0.3",
      "glob": {
        "minimatch": "9.0.9"
      },
      "minimatch": "9.0.9",
      "serialize-javascript": "7.0.4"
    }
  }
}
